# Application Settings
APP_NAME=Financial Stre
DEBUG=false
ENVIRONMENT=development

# Database (optional - app works without it, uses Streamlit cache)
DB_URL=

# Alpha Vantage API Key (required for technical indicators)
# Get free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Price Cache TTL in seconds (default: 300 = 5 minutes)
PRICE_CACHE_TTL_SECONDS=300

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.json

# Sentry (optional - for error monitoring)
SENTRY_DSN=
